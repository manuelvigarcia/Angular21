{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "02_solicitud_datos": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/02_solicitud_datos",
      "sourceRoot": "projects/02_solicitud_datos/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/02_solicitud_datos/src/main.ts",
            "tsConfig": "projects/02_solicitud_datos/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/02_solicitud_datos/public"
              }
            ],
            "styles": ["projects/02_solicitud_datos/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "02_solicitud_datos:build:production"
            },
            "development": {
              "buildTarget": "02_solicitud_datos:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
